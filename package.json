{
  "name": "osbb-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && node scripts/copy-static-assets.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-check.mjs",
    "test:unit": "node --test tests/*.test.mjs",
    "test": "npm run typecheck && npm run test:unit && npm run smoke"
  },
  "devDependencies": {
    "typescript": "latest",
    "vite": "latest"
  }
}
